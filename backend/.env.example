# Supabase Configuration
# Get these from: https://app.supabase.com/project/[your-project-id]/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... (anon key)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... (service key)

# Database Configuration (optional - for direct PostgreSQL connections)
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# FastAPI Configuration
API_TITLE=LabMind Assistant API
API_VERSION=1.0.0
API_DESCRIPTION=Backend API for the LabMind lab completion platform
DEBUG=False
ENVIRONMENT=development

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Server Configuration
HOST=0.0.0.0
PORT=8000
